# Copie este arquivo para .env.local (que é ignorado pelo git) e preencha com
# os valores do seu projeto em https://app.supabase.com/project/_/settings/api
#
# IMPORTANTE: este projeto é Vite (não Next.js) — só variáveis com prefixo
# VITE_ chegam ao navegador. Não use NEXT_PUBLIC_*, não funciona aqui.
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
# No painel do Supabase esse valor aparece como "Publishable key" (antigo nome: "anon key").
VITE_SUPABASE_PUBLISHABLE_KEY=SUA_PUBLISHABLE_KEY

# Usada apenas pelo script scripts/seed-supabase.mjs (Node, nunca roda no navegador).
# No painel do Supabase aparece como "Secret key" (antigo nome: "service_role key").
# NUNCA use essa chave no código do app nem a exponha com prefixo VITE_
# (ficaria pública no bundle) — e nunca a coloque nas env vars da Vercel.
SUPABASE_SERVICE_ROLE_KEY=SUA_SECRET_KEY
