# Copie este arquivo para .env.local (que é ignorado pelo git) e preencha com
# os valores do seu projeto em https://app.supabase.com/project/_/settings/api
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=SUA_ANON_KEY_PUBLICA

# Usada apenas pelo script scripts/seed-supabase.ts (Node, nunca roda no navegador).
# Fica em Settings > API > service_role — NUNCA use essa chave no código do app
# nem a exponha com prefixo VITE_ (ficaria pública no bundle).
SUPABASE_SERVICE_ROLE_KEY=SUA_SERVICE_ROLE_KEY
